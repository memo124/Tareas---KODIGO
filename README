#hola

from abc import ABC, abstractmethod
import pandas as pd
import os
import matplotlib.pyplot as plt
import seaborn as sns

# Paso 1: Clase abstracta base
class DataComponent(ABC):
    @abstractmethod
    def execute(self, *args, **kwargs):
        """Método obligatorio para ejecutar el componente en el pipeline."""
        pass

# Paso 2: LoggerMixin y ValidatorMixin
class LoggerMixin:
    def log_info(self, message):
        print(f"[INFO] [{self.__class__.__name__}]: {message}")
        
    def log_warning(self, message):
        print(f"[WARNING] [{self.__class__.__name__}]: {message}")
        
    def log_error(self, message):
        print(f"[ERROR] [{self.__class__.__name__}]: {message}")

class ValidatorMixin:
    def validate_file_exists(self, file_path):
        if not os.path.exists(file_path):
            raise FileNotFoundError(f"Archivo no encontrado en la ruta: {file_path}")
        return True
        
    def validate_columns(self, df, required_columns):
        missing = [col for col in required_columns if col not in df.columns]
        if missing:
            raise ValueError(f"Faltan columnas requeridas en el dataset: {missing}")
        return True
